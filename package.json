{
  "name": "super",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "allset/devbot/app",
    "allset/devbot/backend",
    "allset/devbot/plugins/*"
  ],
  "description": "Personal projects monorepo with shared ESLint and Prettier configs",
  "scripts": {
    "eslint": "eslint . --ext .ts,.tsx --fix",
    "prettier": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "lint": "npm run prettier && npm run eslint",
    "generate-resume": "tsx resume-builder/generate-resume.mjs"
  },
  "keywords": [
    "automation",
    "linkedin",
    "jobs",
    "monorepo"
  ],
  "author": "Subbiah",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "9.37.0",
    "@typescript-eslint/eslint-plugin": "8.46.1",
    "@typescript-eslint/parser": "8.46.1",
    "eslint": "9.37.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.0",
    "eslint-plugin-react-refresh": "0.4.23",
    "eslint-plugin-storybook": "10.2.7",
    "eslint-plugin-unused-imports": "4.2.0",
    "globals": "16.4.0",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "0.7.0",
    "shadcn": "3.5.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.1"
  }
}

{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git *)",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-main.sh"
          }
        ]
      },
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '📝 Before committing, run /sync-docs to ensure documentation is up to date.'"
          }
        ]
      },
      {
        "matcher": "Bash(supabase db reset*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'BLOCKED: supabase db reset destroys all data. Use \"supabase db push\" to apply pending migrations safely. Run /db-upgrade for the full workflow.' && exit 2"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit(*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✅ Code modified. Remember to run: npm run lint && npm run type-check'"
          }
        ]
      },
      {
        "matcher": "Write(*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✅ File created. Remember to run: npm run lint && npm run type-check'"
          }
        ]
      },
      {
        "matcher": "MultiEdit(*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✅ Multiple files modified. Remember to run: npm run lint && npm run type-check'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/journal-reminder.sh"
          }
        ]
      }
    ]
  }
}

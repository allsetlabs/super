{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '📝 Before committing, run /sync-docs to ensure documentation is up to date.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit(*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✅ Code modified. Remember to run: npm run lint && npm run type-check'"
          }
        ]
      },
      {
        "matcher": "Write(*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✅ File created. Remember to run: npm run lint && npm run type-check'"
          }
        ]
      },
      {
        "matcher": "MultiEdit(*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✅ Multiple files modified. Remember to run: npm run lint && npm run type-check'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-hook.sh"
          }
        ]
      }
    ]
  }
}
